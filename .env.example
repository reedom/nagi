# Slack socket-mode credentials. Create an app at https://api.slack.com/apps,
# enable Socket Mode + Interactivity, and add the scopes listed in README.md.
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# Path to the JSON config (see nagi.config.example.json). Optional.
NAGI_CONFIG=./nagi.config.json
